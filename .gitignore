# ═══════════════════════════════════════════════════
# Lazy-Trading-Bot  .gitignore
# ═══════════════════════════════════════════════════

# ── Secrets / Environment ──────────────────────────
.env
*.env
!.env.example

# ── Data / Database ────────────────────────────────
data/
*.duckdb
*.duckdb.wal
*.db
*.sqlite
*.sqlite3

# ── Logs & Reports ─────────────────────────────────
logs/
reports/
*.log

# ── Python ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
venv/
.venv/
*.whl
pip-wheel-metadata/

# ── Testing / Linting Caches ──────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
results.xml

# ── Debug / Output Artifacts ───────────────────────
_debug_output/
*.tmp
*.out
*_output*.txt
*_out*.txt

# ── Temporary reproduce / verify / dump scripts ───
reproduce_*.py
verify_*.py
dump_errs*.py
parse_results.py

# ── Scratch test files (root level) ────────────────
tests/scratch/

# ── User Config (local watchlists, LLM settings) ──
# These contain user-specific local preferences
app/user_config/llm_config.json
app/user_config/watchlist.json
app/user_config/risk_params.json

# ── IDE / Editor ───────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── OS ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Keys / Certs (safety net) ─────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# ── Antigravity agent outputs ─────────────────────
.antigravity-outputs/

# ── Node (for example_repos subprojects) ──────────
node_modules/
